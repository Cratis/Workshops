{
    "private": true,
    "workspaces": [
        "EventModelingConference2026/Core"
    ],
    "engines": {
        "node": ">=23.0.0"
    },
    "scripts": {
        "g:clean": "cd $INIT_CWD && tsc -b --clean .frontend/tsconfig.json",
        "g:build": "cd $INIT_CWD && vite build --config .frontend/vite.config.ts",
        "g:lint": "cd $INIT_CWD && eslint --cache --quiet --fix",
        "g:lint:ci": "cd $INIT_CWD && eslint --cache --quiet",
        "g:test": "cd $INIT_CWD && vitest run --config .frontend/vite.config.ts",
        "g:test:watch": "cd $INIT_CWD && vitest --watch --config .frontend/vite.config.ts",
        "g:test:debug": "DEBUG=vite:proxy && cd $INIT_CWD && vitest --watch --config .frontend/vite.config.ts",
        "g:ci": "cd $INIT_CWD && yarn test && yarn lint:ci && tsc -b .frontend/tsconfig.json",
        "g:update": "cd $INIT_CWD && ncu -u && yarn",
        "g:preview": "cd $INIT_CWD && vite preview --config .frontend/vite.config.ts",
        "g:dev": "cd $INIT_CWD && vite --config .frontend/vite.config.ts",
        "g:dev:debug": "DEBUG=vite:proxy && cd $INIT_CWD && vite --config .frontend/vite.config.ts",
        "g:compile": "cd $INIT_CWD && tsc -b .frontend/tsconfig.json",
        "clean": "node ./run-task-on-workspaces.cjs clean",
        "build": "node ./run-task-on-workspaces.cjs build",
        "lint": "node ./run-task-on-workspaces.cjs lint",
        "test": "node ./run-task-on-workspaces.cjs test",
        "ci": "node ./run-task-on-workspaces.cjs ci",
        "publish-version": "node ./run-task-on-workspaces.cjs publish-version $*",
        "update": "node ./run-task-on-workspaces.cjs update"
    },
    "devDependencies": {
        "@eslint/eslintrc": "3.3.5",
        "@eslint/js": "10.0.1",
        "@tailwindcss/postcss": "4.3.1",
        "@tailwindcss/vite": "4.3.1",
        "@types/chai": "5.2.3",
        "@types/chai-as-promised": "8.0.2",
        "@types/mocha": "10.0.10",
        "@types/node": "26.0.1",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@types/sinon": "21.0.1",
        "@types/sinon-chai": "4.0.0",
        "@typescript-eslint/eslint-plugin": "8.62.0",
        "@typescript-eslint/parser": "8.62.0",
        "@vitejs/plugin-react": "6.0.3",
        "@vitest/coverage-v8": "4.1.9",
        "autoprefixer": "10.5.2",
        "chai": "6.2.2",
        "chai-as-promised": "8.0.2",
        "edit-json-file": "1.8.1",
        "eslint": "10.5.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-header": "3.1.1",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-no-null": "1.0.2",
        "eslint-plugin-prettier": "5.5.6",
        "eslint-plugin-react": "7.37.5",
        "glob": "13.0.6",
        "globals": "17.7.0",
        "mocha": "11.7.6",
        "module-alias": "2.3.4",
        "npm-check-updates": "22.2.7",
        "prettier": "3.8.4",
        "rollup": "4.62.2",
        "rollup-plugin-commonjs": "10.1.0",
        "rollup-plugin-peer-deps-external": "2.2.4",
        "rollup-plugin-typescript2": "0.37.0",
        "sinon": "22.0.0",
        "sinon-chai": "4.0.1",
        "tailwindcss": "4.3.1",
        "ts-node": "10.9.2",
        "typescript": "6.0.3",
        "typescript-eslint": "8.62.0",
        "vite": "8.1.0",
        "vite-plugin-commonjs": "0.10.4",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.1.9"
    },
    "license": "MIT",
    "version": "0.0.0",
    "packageManager": "yarn@4.5.3"
}
